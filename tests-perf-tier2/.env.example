# Tier 2 perf test environment variables
# Copy to .env and fill in values.

# --- Staging API ---
PERF_TEST_HOST=https://api.staging.notification.cdssandbox.xyz

# --- Single service (Layer 1 & 2) ---
PERF_TEST_API_KEY=
PERF_TEST_SMS_TEMPLATE_ID=
PERF_TEST_EMAIL_TEMPLATE_ID=

# --- Multi-service (Layer 3) ---
# Comma-separated full API keys, one per service.
PERF_TEST_API_KEYS=

# --- Limits (defaults match Tier 2) ---
PERF_TEST_SMS_DAILY_LIMIT=1500
PERF_TEST_EMAIL_DAILY_LIMIT=10000
